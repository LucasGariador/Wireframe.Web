@page "/"
@using Blazor.Extensions
@using Blazor.Extensions.Canvas
@using Blazor.Extensions.Canvas.Canvas2D
@using WireframeCrawler.Domain
@using WireframeCrawler.Domain.Models

<PageTitle>Terminal de Telemetría</PageTitle>

<div class="dashboard-container">
    <!-- Panel Izquierdo: Consola y Comandos -->
    <div class="console-panel">
        <div class="log-container">
            @foreach (var log in _actionLogs)
            {
                <div class="log-entry">> @log</div>
            }
        </div>
        <div class="input-container">
            <span class="prompt">></span>

            <input type="text" class="command-input" @bind="_currentCommand" @bind:event="oninput" @onkeyup="HandleKeyUp" autofocus placeholder="Ingresar comando..." autocomplete="off" />
        </div>
    </div>

    <!-- Panel Derecho: Radar -->
    <div class="radar-panel">
        <BECanvas Width="400" Height="400" @ref="_canvasReference" />
    </div>
</div>

<style>
    body {
        background-color: #050505;
        color: #33ff33;
        font-family: 'Courier New', Courier, monospace;
        margin: 0;
        height: 100vh;
        display: flex;
        flex-direction: column;
    }
    .dashboard-container {
        display: flex;
        flex: 1;
        padding: 20px;
        gap: 20px;
        height: calc(100vh - 40px);
    }
    .console-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        border: 1px solid #202720;
        padding: 10px;
        background-color: #0a0a0a;
    }
    .log-container {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        justify-content: flex-end; /* Mantiene el texto nuevo abajo */
        margin-bottom: 10px;
    }
    .log-entry {
        margin-bottom: 5px;
        line-height: 1.4;
    }
    .input-container {
        display: flex;
        align-items: center;
        border-top: 1px dashed #33ff33;
        padding-top: 10px;
    }
    .prompt {
        margin-right: 10px;
        font-weight: bold;
    }
    .command-input {
        flex: 1;
        background: transparent;
        border: none;
        color: #33ff33;
        font-family: inherit;
        font-size: 1rem;
        outline: none;
    }
    .radar-panel {
        width: 400px;
        border: 1px solid #33ff33;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: #000;
    }
</style>

@code {
    private BECanvasComponent _canvasReference = null!;
    private Canvas2DContext _context = null!;

    private GameMap _map = null!;
    private Player _player = null!;
    private Engine _engine = null!;
    private CommandParser _parser = null!;

    // Variables para la consola
    private string _currentCommand = "";
    private List<string> _actionLogs = new List<string> 
    { 
        "SISTEMA INICIADO. TELEMETRÍA EN LÍNEA.", 
        "SOPORTE VITAL: ESTABLE.",
        "Esperando comandos de navegación..." 
    };

    protected override void OnInitialized()
    {
        _map = new GameMap();
        _parser = new CommandParser();
        _player = new Player(1, 3, Direction.North); 
        _engine = new Engine(400, 400); // Ajustamos la resolución interna del radar
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _context = await _canvasReference.CreateCanvas2DAsync();
            await DrawFrameAsync();
        }
    }

    // Intercepta la tecla Enter en el input
    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_currentCommand))
        {
            ProcessCommand(_currentCommand.Trim().ToLower());
            _currentCommand = ""; // Limpiamos el input
            
            await DrawFrameAsync(); 
        }
    }

    private void ProcessCommand(string input)
    {
        _actionLogs.Add($"> {input}"); // Eco de lo que el usuario escribió

        // El Dominio hace todo el trabajo y devuelve la respuesta
        string response = _parser.ParseAndExecute(input, _player, _map);
        
        _actionLogs.Add(response);

        if (_actionLogs.Count > 15) _actionLogs.RemoveAt(0);
    }

    private void MovePlayer(int steps)
    {
        // Calculamos el vector de movimiento usando nuestro motor
        int fwdX = 0, fwdY = 0;
        
        switch (_player.Facing)
        {
            case Direction.North: fwdY = -1; break;
            case Direction.East: fwdX = 1; break;
            case Direction.South: fwdY = 1; break;
            case Direction.West: fwdX = -1; break;
        }

        int targetX = _player.X + (fwdX * steps);
        int targetY = _player.Y + (fwdY * steps);

        if (_map.IsWall(targetX, targetY))
        {
            _actionLogs.Add("[ALERTA] Colisión inminente detectada. Movimiento abortado.");
        }
        else
        {
            _player.X = targetX;
            _player.Y = targetY;
            _actionLogs.Add("Motores activados. Posición actualizada.");
        }
    }

    private void RotatePlayer(int direction)
    {
        // Rotamos usando el enum (0 a 3). direction es -1 (izq) o 1 (der)
        int currentFacing = (int)_player.Facing;
        currentFacing = (currentFacing + direction + 4) % 4; // El +4 evita números negativos en el módulo
        _player.Facing = (Direction)currentFacing;
    }

    private async Task DrawFrameAsync()
    {
        await _context.ClearRectAsync(0, 0, 400, 400);

        // 1. Recibimos la Tupla con muros y entidades
        var radarData = _engine.ScanRadar(_map, _player, 5, 40);

        string terminalGreen = "#33ff33";
        await _context.SetStrokeStyleAsync(terminalGreen);
        await _context.SetFillStyleAsync(terminalGreen);
        await _context.SetLineWidthAsync(2);

        // 2. Dibujamos los muros (radarData.Walls)
        foreach (var blip in radarData.Walls)
        {
            await _context.BeginPathAsync();
            await _context.MoveToAsync(blip.X1, blip.Y1);
            await _context.LineToAsync(blip.X2, blip.Y2);
            await _context.LineToAsync(blip.X3, blip.Y3);
            await _context.LineToAsync(blip.X4, blip.Y4);
            await _context.ClosePathAsync();
            await _context.StrokeAsync(); 
        }

        // 3. Dibujamos las Entidades dinámicamente (radarData.Entities)
        foreach (var ent in radarData.Entities)
        {
            await _context.BeginPathAsync();
            
            if (ent.Type == EntityType.Passage) // Círculo
            {
                await _context.ArcAsync(ent.ScreenX, ent.ScreenY, 10, 0, Math.PI * 2);
            }
            else if (ent.Type == EntityType.InteractableZone) // Cuadrado
            {
                await _context.StrokeRectAsync(ent.ScreenX - 8, ent.ScreenY - 8, 16, 16);
            }
            else if (ent.Type == EntityType.FoundObject) // 'X' (Objeto a recolectar)
            {
                int size = 6;
                // Línea diagonal \
                await _context.MoveToAsync(ent.ScreenX - size, ent.ScreenY - size);
                await _context.LineToAsync(ent.ScreenX + size, ent.ScreenY + size);
                // Línea diagonal /
                await _context.MoveToAsync(ent.ScreenX + size, ent.ScreenY - size);
                await _context.LineToAsync(ent.ScreenX - size, ent.ScreenY + size);
            }
            
            await _context.StrokeAsync();
        }

        // 4. Dibujar al jugador (Nave en el centro)
        int centerX = 200; 
        int centerY = 200; 
        
        await _context.BeginPathAsync();
        await _context.MoveToAsync(centerX, centerY - 15);
        await _context.LineToAsync(centerX - 10, centerY + 10);
        await _context.LineToAsync(centerX + 10, centerY + 10);
        await _context.ClosePathAsync();
        await _context.FillAsync(); 
    }
}